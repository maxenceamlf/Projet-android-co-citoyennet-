<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Thème de base : Material3 sans ActionBar (on utilise notre propre toolbar) -->
    <style name="Base.Theme.PowerHome" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_dark</item>
        <item name="colorPrimaryVariant">@color/green_medium</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>

    <style name="Theme.PowerHome" parent="Base.Theme.PowerHome" />

    <!-- Style pour les images circulaires (ShapeableImageView) -->
    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

</resources>
