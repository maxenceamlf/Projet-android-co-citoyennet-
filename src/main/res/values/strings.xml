<?xml version="1.0" encoding="utf-8"?>
<!--
    strings.xml — Toutes les chaînes de caractères de l'application.

    Bonne pratique : centraliser ici toutes les chaînes permet de :
    - Faciliter la traduction (internationalisation)
    - Éviter les chaînes hardcodées dans le code Java
    - Maintenir la cohérence de l'interface
-->
