<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_resident_detail.xml — Boîte de dialogue de détail d'un habitat.
    Ouverte depuis HabitatAdapter au clic sur un item de la liste.
    Affiche : nom, étage, surface, liste dynamique des équipements, total watts.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- En-tête vert -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nom de l'habitat -->
            <TextView
                android:id="@+id/dialogTvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom Habitat"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Étage et surface sur une ligne -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/dialogTvFloor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Étage : —"
                    android:textColor="#B9F6CA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/dialogTvArea"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Surface : — m²"
                    android:textColor="#B9F6CA"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Corps : liste des équipements -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Équipements"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Conteneur dynamique : rempli par HabitatAdapter -->
            <LinearLayout
                android:id="@+id/dialogAppliancesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:background="#EEEEEE" />

            <!-- Total consommation -->
            <TextView
                android:id="@+id/dialogTvTotalWattage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="end"
                android:text="Total : — W"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Bouton Fermer -->
        <Button
            android:id="@+id/btnCloseDialog"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:backgroundTint="#1B5E20"
            android:text="FERMER"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
