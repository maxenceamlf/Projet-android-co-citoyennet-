<?xml version="1.0" encoding="utf-8"?>
<!--
    item_habitat.xml — Élément de la ListView des habitats.
    Chaque carte affiche : nom du résident, nombre d'équipements,
    icônes des équipements, consommation totale et numéro d'étage.
    Le ViewHolder dans HabitatAdapter optimise le recyclage.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Bloc gauche : infos principale -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Nom du résident / habitat -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nom Habitat"
                android:textColor="#111111"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- Ligne : nb équipements + icônes -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEquip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 équipement"
                    android:textColor="#888888"
                    android:textSize="13sp" />

                <!-- Icônes des équipements (ajoutées dynamiquement) -->
                <LinearLayout
                    android:id="@+id/iconsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- Consommation totale en watts -->
            <TextView
                android:id="@+id/tvWattage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 W"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Badge ÉTAGE (droite) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_etage_badge"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ÉTAGE"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFloorNumber"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_etage_number"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
