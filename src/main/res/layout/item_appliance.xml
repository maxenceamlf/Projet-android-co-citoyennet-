<?xml version="1.0" encoding="utf-8"?>
<!--
    item_appliance.xml — Ligne représentant un équipement dans "Mon habitat".
    Affiche : icône (si disponible), nom de l'équipement et consommation en W.
    Utilisé dans MyHabitatFragment via LayoutInflater dans la boucle d'équipements.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Nom de l'équipement -->
    <TextView
        android:id="@+id/tv_appliance_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Équipement"
        android:textColor="#444444"
        android:textSize="14sp" />

    <!-- Consommation en watts -->
    <TextView
        android:id="@+id/tv_appliance_wattage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 W"
        android:textColor="#1B5E20"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
