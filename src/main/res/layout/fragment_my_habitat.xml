<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_my_habitat.xml — Fragment "Mon habitat".
    Affiche les informations de l'habitat du résident connecté :
    nom, étage, surface, consommation totale, éco-coins et équipements.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Message de bienvenue -->
        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Bonjour !"
            android:textColor="#1B5E20"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Indicateur de chargement -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#1B5E20"
            android:visibility="gone" />

        <!-- Message si pas d'habitat assigné -->
        <TextView
            android:id="@+id/tv_no_habitat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:text="Aucun habitat assigné à votre compte.\nContactez l'administrateur de la résidence."
            android:textAlignment="center"
            android:textColor="#8b8b8b"
            android:textSize="15sp"
            android:visibility="gone" />

        <!-- Carte principale de l'habitat -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_habitat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Nom de l'habitat -->
                <TextView
                    android:id="@+id/tv_habitat_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#1B5E20"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Étage et surface sur une ligne -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tv_floor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:drawableStart="@android:drawable/ic_menu_sort_by_size"
                        android:drawablePadding="8dp"
                        android:text="Étage —"
                        android:textColor="#555555"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_area"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="— m²"
                        android:textColor="#555555"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Séparateur -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="#E0E0E0" />

                <!-- Consommation totale -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Consommation totale"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_total_wattage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— W"
                        android:textColor="#1B5E20"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Éco-coins -->
                <TextView
                    android:id="@+id/tv_eco_coins"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="#E8F5E9"
                    android:padding="10dp"
                    android:text="0 éco-coins 🌿"
                    android:textColor="#2E7D32"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Titre section équipements -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Mes équipements"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Conteneur dynamique des équipements -->
                <LinearLayout
                    android:id="@+id/appliances_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bouton modifier mon profil -->
        <Button
            android:id="@+id/btn_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="#1B5E20"
            android:text="MODIFIER MON PROFIL"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>
</ScrollView>
